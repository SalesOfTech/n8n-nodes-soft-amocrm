{
  "name": "n8n-nodes-soft-amocrm",
  "version": "0.1.2",
  "description": "SOFT fork of n8n node for AmoCRM API",
  "keywords": [
    "n8n-community-node-package",
    "amocrm",
    "n8n"
  ],
  "license": "MIT",
  "homepage": "https://github.com/SalesOfTech/n8n-nodes-soft-amocrm",
  "author": {
    "name": "SOFT Company",
    "url": "https://salesof.tech"
  },
  "contributors": [
    {
      "name": "Yaroslav Tolstoy",
      "url": "https://t.me/yatolstoy"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SalesOfTech/n8n-nodes-soft-amocrm.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/amocrmOAuth2Api.credentials.js",
      "dist/credentials/amocrmLongLivedApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Amocrm/SoftAmocrm.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.6",
    "@types/request-promise-native": "~1.0.15",
    "@typescript-eslint/parser": "~5.45",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^5.0.0",
    "n8n-core": "*",
    "n8n-workflow": "*",
    "prettier": "^2.7.1",
    "typescript": "~4.8.4"
  },
  "dependencies": {
    "async-await-mutex-lock": "^1.0.11"
  }
}
